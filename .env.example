# Created by `npm run convex:dev`.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Genome Firewall inference service (inference/serve.py, deployed by the team).
# Set these in the Convex dashboard, NOT in Next.js/Vercel:
#   npx convex env set INFERENCE_API_URL https://your-inference-host
#   npx convex env set INFERENCE_API_TOKEN <optional-shared-secret>
# The action POSTs {fasta, antibiotic} to `${INFERENCE_API_URL}/predict`.
INFERENCE_API_URL=
INFERENCE_API_TOKEN=

# AI reviewer subagent (convex/report.ts generateReport, OpenAI gpt-4o-mini).
# Set in the Convex dashboard, NOT in Next.js/Vercel:
#   npx convex env set OPENAI_API_KEY sk-...
# Without it, the classifier result still renders; only the AI report is skipped.
OPENAI_API_KEY=
